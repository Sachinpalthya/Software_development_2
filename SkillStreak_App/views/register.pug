extends layout

block content
  .auth-container(style="display: flex; min-height: 85vh;")
    // Left side: Value prop
    .auth-sidebar(style="flex: 1; padding: 60px; display: flex; flex-direction: column; justify-content: center;")
      a.navbar-brand(href="/", style="margin-bottom: 60px;")
        .logo-icon
        | SkillStreak
        
      h1(style="font-size: 48px; margin-bottom: 24px;") Start your learning #[br] #[span(style="color: var(--primary);") Journey.]
      p(style="font-size: 18px; color: var(--text-muted); max-width: 400px; margin-bottom: 40px;") Join us our learners building daily habits, earning exclusive badges, and climbing the global leaderboard.
      
      .rewards-card(style="background: white; border-radius: 20px; padding: 32px; box-shadow: var(--shadow-lg); max-width: 450px;")
        h3(style="font-size: 18px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center;")
          | Your Potential Rewards
          i.fas.fa-award(style="color: var(--primary);")
        
        .rewards-grid(style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px;")
          .reward-item(style="background: var(--bg-color); padding: 16px 8px; border-radius: 12px; text-align: center;")
            .icon(style="width: 40px; height: 40px; background: #ffe4d6; color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px;")
              i.fas.fa-fire
            div(style="font-size: 12px; font-weight: 600;") 7 Day Streak
          .reward-item(style="background: var(--bg-color); padding: 16px 8px; border-radius: 12px; text-align: center;")
            .icon(style="width: 40px; height: 40px; background: #e0f2fe; color: #0284c7; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px;")
              i.fas.fa-medal
            div(style="font-size: 12px; font-weight: 600;") Skill Master
          .reward-item(style="background: var(--bg-color); padding: 16px 8px; border-radius: 12px; text-align: center;")
            .icon(style="width: 40px; height: 40px; background: #dcfce7; color: #16a34a; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px;")
              i.fas.fa-chart-bar
            div(style="font-size: 12px; font-weight: 600;") Top 10%
            
        h4(style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px;") Top Learners This Week
        .learner-list(style="display: flex; flex-direction: column; gap: 16px;")
          .learner(style="display: flex; justify-content: space-between; align-items: center; padding: 12px; border: 1px solid var(--primary); border-radius: 8px; background: #fffcfb;")
            .learner-info(style="display: flex; align-items: center; gap: 12px;")
              .avatar(style="width: 32px; height: 32px; background: #ffd8cc; border-radius: 50%;")
              span(style="font-weight: 600; font-size: 14px;") rakshitha
            span(style="color: var(--primary); font-weight: bold; font-size: 14px;") 2,450 XP
          .learner(style="display: flex; justify-content: space-between; align-items: center; padding: 12px; border: 1px solid var(--gray-100); border-radius: 8px;")
            .learner-info(style="display: flex; align-items: center; gap: 12px;")
              .avatar(style="width: 32px; height: 32px; background: #e2e8f0; border-radius: 50%;")
              span(style="font-weight: 500; font-size: 14px;") deekshitha 
            span(style="color: var(--text-muted); font-size: 14px;") 2,100 XP

    // Right side: Form
    .auth-form-wrapper(style="flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px;")
      .auth-card(style="background: white; border-radius: 24px; padding: 48px; width: 100%; max-width: 500px; box-shadow: var(--shadow-lg);")
        h2(style="font-size: 28px; margin-bottom: 8px;") Create Account
        p(style="color: var(--text-muted); margin-bottom: 32px;") Join us to make your streak and start mastering new skills today.
        
        form(action="/register", method="POST")
          .form-group(style="margin-bottom: 24px;")
            label.form-label I want to join as a:
            .role-selector(style="display: flex; border: 1px solid var(--gray-200); border-radius: 8px; overflow: hidden; background: var(--gray-100); padding: 4px;")
              label.role-label(style="flex: 1; text-align: center; cursor: pointer;")
                input(type="radio", name="role", value="student", checked, style="display:none;")
                .role-box Student
              label.role-label(style="flex: 1; text-align: center; cursor: pointer;")
                input(type="radio", name="role", value="mentor", style="display:none;")
                .role-box Mentor
                
          .form-group
            label.form-label Full Name
            .input-with-icon(style="position: relative;")
              i.far.fa-user(style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted);")
              input.form-input(type="text", name="full_name", placeholder="your name please", style="padding-left: 44px;", required)
              
          .form-group
            label.form-label Email Address
            .input-with-icon(style="position: relative;")
              i.far.fa-envelope(style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted);")
              input.form-input(type="email", name="email", placeholder="youremail@gmail.com", style="padding-left: 44px;", required)
              
          .form-row(style="display: flex; gap: 16px; margin-bottom: 24px;")
            .form-group(style="flex: 1; margin-bottom: 0;")
              label.form-label Password
              .input-with-icon(style="position: relative;")
                i.fas.fa-lock(style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted);")
                input.form-input(type="password", name="password", placeholder="your password please", style="padding-left: 44px;", required)
            .form-group(style="flex: 1; margin-bottom: 0;")
              label.form-label Confirm
              .input-with-icon(style="position: relative;")
                i.fas.fa-shield-alt(style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted);")
                input.form-input(type="password", name="password_confirm", placeholder="your password please", style="padding-left: 44px;", required)
                
          .form-group(style="display: flex; align-items: flex-start; gap: 12px; margin-bottom: 24px;")
            input(type="checkbox", id="terms", required, style="margin-top: 4px;")
            label(for="terms", style="font-size: 14px; color: var(--text-muted);") I agree to the #[a(href="#", style="color: var(--primary);") Terms of Service] and #[a(href="#", style="color: var(--primary);") Privacy Policy].
            
          if error
             .error-message(style="color: #dc2626; background: #fee2e2; padding: 12px; border-radius: 8px; font-size: 14px; margin-bottom: 20px;") #{error}
          
          button.btn.btn-primary(type="submit", style="width: 100%; padding: 14px; font-size: 16px; margin-bottom: 24px;") Create Account →
          
          .divider(style="display: flex; align-items: center; text-align: center; color: var(--text-muted); font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 24px;")
            span(style="flex: 1; height: 1px; background: var(--gray-200);")
            span(style="padding: 0 16px;") OR CONTINUE WITH
            span(style="flex: 1; height: 1px; background: var(--gray-200);")
            
          a.btn.btn-outline(href="/auth/google", style="width: 100%; padding: 12px; display: flex; align-items: center; justify-content: center; gap: 12px; text-decoration: none;")
            img(src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg", width="18", height="18")
            | Sign up with Google
