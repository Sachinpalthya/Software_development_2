extends layout

block content
  .auth-container(style="display: flex; min-height: 100vh; align-items: center; justify-content: center; background-color: var(--bg-color); padding: 40px;")
    .auth-box(style="display: flex; background: white; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-lg); width: 100%; max-width: 1000px; min-height: 600px;")
      
      // Left side: Graphic
      .login-graphic(style="flex: 1; background: linear-gradient(135deg, #a63412 0%, #3d140e 100%); padding: 60px; color: white; display: flex; flex-direction: column;")
        a.navbar-brand(href="/", style="color: white; margin-bottom: auto;")
          .logo-icon(style="background: white;")
            span(style="color: var(--primary);") ⚡
          | SkillStreak
          
        div(style="margin-bottom: 60px;")
          h1(style="font-size: 40px; margin-bottom: 24px; line-height: 1.2; font-family: var(--font-heading); font-weight: 700;") Level up your #[br] career today.
          p(style="font-size: 16px; opacity: 0.9; line-height: 1.6; max-width: 300px;") Join over 50,000 developers mastering new skills through daily streaks and interactive challenges.
          
        .feature-callout(style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; padding: 16px; display: flex; align-items: center; gap: 16px; backdrop-filter: blur(10px); margin-top: auto;")
          .icon(style="width: 40px; height: 40px; background: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;")
            i.fas.fa-sparkles
          p(style="font-size: 14px; margin: 0; font-weight: 500;") Personalized learning BY S-Five Coders.
          
      // Right side: Login Form
      .login-form-area(style="flex: 1.2; padding: 60px 80px; display: flex; flex-direction: column; justify-content: center;")
        h2(style="font-size: 32px; margin-bottom: 8px;") Welcome Back
        p(style="color: var(--text-muted); margin-bottom: 40px;") Enter your credentials to continue your journey.
        
        form(action="/login", method="POST")
          .form-group
            label.form-label Email Address
            .input-with-icon(style="position: relative;")
              i.far.fa-envelope(style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted);")
              input.form-input(type="email", name="email", placeholder="name@example.com", style="padding-left: 44px; background: #f9fbfc;", required)
              
          .form-group(style="margin-bottom: 24px;")
            .label-row(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;")
              label.form-label(style="margin: 0;") Password
              a(href="javascript:void(0)", onclick="alert('Forgot password feature coming soon!');", style="font-size: 12px; color: var(--primary); font-weight: 600;") Forgot Password?
            .input-with-icon(style="position: relative;")
              i.fas.fa-lock(style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted);")
              input.form-input#password(type="password", name="password", placeholder="Your password please", style="padding-left: 44px; background: #f9fbfc;", required)
              i.far.fa-eye#togglePassword(style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted); cursor: pointer;")
              
          .form-group(style="display: flex; align-items: center; gap: 8px; margin-bottom: 32px;")
            input(type="checkbox", id="remember")
            label(for="remember", style="font-size: 14px; color: var(--text-muted);") Remember me for 30 days
            
          if error
             .error-message(style="color: #dc2626; background: #fee2e2; padding: 12px; border-radius: 8px; font-size: 14px; margin-bottom: 20px;") #{error}

          button.btn.btn-primary(type="submit", style="width: 100%; padding: 14px; font-size: 16px; margin-bottom: 24px;") Sign In
          
          .divider(style="display: flex; align-items: center; text-align: center; color: var(--text-muted); font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 24px;")
            span(style="flex: 1; height: 1px; background: var(--gray-200);")
            span(style="padding: 0 16px;") Or continue with
            span(style="flex: 1; height: 1px; background: var(--gray-200);")
            
          a.btn.btn-outline(href="/auth/google", style="width: 100%; padding: 12px; display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 32px; text-decoration: none;")
            img(src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg", width="18", height="18")
            | Google
            
          .text-center(style="text-align: center; font-size: 14px; color: var(--text-muted);")
            | Don't have an account? #[a(href="/register", style="color: var(--primary); font-weight: 600;") Sign Up]

  script.
    document.addEventListener('DOMContentLoaded', function() {
      const togglePassword = document.getElementById('togglePassword');
      const password = document.getElementById('password');

      if (togglePassword && password) {
        togglePassword.addEventListener('click', function() {
          const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
          password.setAttribute('type', type);
          this.classList.toggle('fa-eye');
          this.classList.toggle('fa-eye-slash');
        });
      }
    });
