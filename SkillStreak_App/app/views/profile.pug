extends layout

block content
  style.
    body {
      background-color: #0b0f19 !important;
      color: #e2e8f0 !important;
    }
    .navbar {
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .navbar-brand, .navbar-menu a {
      color: #f1f5f9 !important;
    }
    .navbar-menu a:hover, .navbar-menu a.active {
      color: var(--primary) !important;
    }
    .navbar-actions .search-bar input {
      background: rgba(255,255,255,0.05);
      border-color: rgba(255,255,255,0.1);
      color: #fff;
    }
    footer {
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .footer-desc, .footer-links h4, .footer-links ul li a {
      color: #94a3b8 !important;
    }
    
    .profile-header {
      margin-top: 40px;
      display: flex;
      align-items: center;
      gap: 30px;
      margin-bottom: 40px;
      position: relative;
    }
    .profile-avatar {
      width: 140px;
      height: 140px;
      border-radius: 20px;
      background: linear-gradient(135deg, #4ade80, #3b82f6);
      padding: 3px;
    }
    .profile-avatar img {
      width: 100%;
      height: 100%;
      border-radius: 17px;
      object-fit: cover;
      background: #1e293b;
    }
    .profile-info h1 {
      font-size: 42px;
      color: #ffffff;
      margin: 10px 0 5px;
    }
    .profile-info p {
      font-size: 18px;
      color: #94a3b8;
    }
    .badges-row {
      display: flex;
      gap: 12px;
      margin-bottom: 8px;
    }
    .badge-premium {
      background: rgba(255, 180, 0, 0.1);
      color: #fbbf24;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .badge-streak {
      background: rgba(242, 98, 46, 0.1);
      color: #f2622e;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .edit-btn {
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      background: #f2622e;
      color: white !important;
      padding: 12px 24px;
      border-radius: 10px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: background 0.2s;
    }
    .edit-btn:hover {
      background: #e05220;
    }
    
    .dashboard-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 30px;
      margin-bottom: 60px;
    }
    
    .section-title {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #f2622e;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .section-heading {
      font-size: 24px;
      color: white;
      margin-bottom: 24px;
    }
    
    .course-card {
      background: #151a27;
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 16px;
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 20px;
      transition: transform 0.2s;
    }
    .course-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }
    .course-icon {
      width: 60px;
      height: 60px;
      border-radius: 12px;
      background: rgba(242, 98, 46, 0.1);
      color: #f2622e;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
    }
    .course-details {
      flex: 1;
    }
    .course-title {
      font-size: 18px;
      color: white;
      margin-bottom: 12px;
      font-weight: 600;
    }
    .progress-bar {
      height: 6px;
      background: rgba(255,255,255,0.1);
      border-radius: 3px;
      margin-bottom: 12px;
      overflow: hidden;
      display: flex;
      width: 100%;
    }
    .progress-fill {
      height: 100%;
      background: #f2622e;
      border-radius: 3px;
    }
    .course-meta {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      color: #94a3b8;
    }
    .continue-btn {
      background: rgba(255,255,255,0.05);
      color: white !important;
      padding: 10px 20px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 14px;
      transition: background 0.2s;
    }
    .continue-btn:hover {
      background: rgba(255,255,255,0.1);
    }
    
    .achievements-row {
      display: flex;
      gap: 24px;
    }
    .achievement {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      opacity: 0.5;
    }
    .achievement.achieved {
      opacity: 1;
    }
    .ach-icon {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      background: #1e293b;
      border: 2px solid rgba(255,255,255,0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      color: #f59e0b;
      position: relative;
    }
    .achievement.achieved .ach-icon {
      border-color: #f59e0b;
      background: rgba(245, 158, 11, 0.1);
    }
    .ach-badge {
      position: absolute;
      bottom: -4px;
      right: -4px;
      background: #f2622e;
      color: white;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      border: 2px solid #0b0f19;
    }
    .ach-name {
      font-size: 13px;
      color: white;
      font-weight: 500;
    }
    
    .side-card {
      background: #151a27;
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 24px;
    }
    .side-card h3 {
      font-size: 18px;
      color: white;
      margin-bottom: 24px;
      font-weight: 600;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .stat-box .label {
      font-size: 11px;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6px;
      font-weight: 600;
    }
    .stat-box .value {
      font-size: 24px;
      color: #f2622e;
      font-weight: 700;
    }
    .stat-box .value.white {
      color: white;
    }
    
    .goal-circle {
      position: relative;
      width: 160px;
      height: 160px;
      margin: 0 auto 20px;
      border-radius: 50%;
      background: conic-gradient(#f2622e var(--pct), rgba(255,255,255,0.05) 0);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .goal-circle::before {
      content: "";
      position: absolute;
      inset: 10px;
      background: #151a27;
      border-radius: 50%;
    }
    .goal-text {
      position: relative;
      text-align: center;
    }
    .goal-text .pct {
      font-size: 32px;
      font-weight: 700;
      color: white;
      line-height: 1.2;
    }
    .goal-text .lbl {
      font-size: 10px;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }
    
    .milestone-item {
      display: flex;
      gap: 16px;
      margin-bottom: 16px;
      background: rgba(255,255,255,0.02);
      padding: 16px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.02);
    }
    .ms-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
    }
    .ms-details {
       flex: 1;
    }
    .ms-details h4 {
      font-size: 15px;
      color: white;
      margin-bottom: 4px;
      font-weight: 600;
    }
    .ms-details p {
      font-size: 12px;
      color: #94a3b8;
    }
    
    /* Top horizontal dividing line for achievements */
    .achievements-divider {
      margin-top: 50px;
      padding-top: 40px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }

  .container
    .profile-header
      .profile-avatar
        if stats.gender === 'female'
          img(src="https://avatar.iran.liara.run/public/girl?username=" + stats.fullName, alt="Profile")
        else if stats.gender === 'male'
          img(src="https://avatar.iran.liara.run/public/boy?username=" + stats.fullName, alt="Profile")
        else
          img(src="https://avatar.iran.liara.run/public?username=" + stats.fullName, alt="Profile")
      .profile-info
        .badges-row
          span.badge-premium PRO MEMBER
          span.badge-streak 
            i.fas.fa-fire
            | #{stats.streak} Day Streak
        h1= stats.fullName
        p= stats.role
      a.edit-btn(href="#")
        i.fas.fa-pen
        | Edit Profile

    .dashboard-grid
      .main-content
        .section-title RESUME LEARNING
        h2.section-heading Currently Enrolled

        if courses && courses.length > 0
          each course in courses
            .course-card
              .course-icon
                i(class="fab " + course.icon)
              .course-details
                h3.course-title= course.courseTitle
                .progress-bar
                  .progress-fill(style="width: " + course.progress + "%")
                .course-meta
                  span 
                    i.far.fa-clock(style="margin-right: 6px;")
                    | #{course.timeLeft}
                  span 
                    i.fas.fa-book-open(style="margin-right: 6px;")
                    | #{course.completed_lessons}/#{course.total_lessons} Lessons
              a.continue-btn(href="/course/" + course.course_id) Continue Class
        else
          p(style="color: #94a3b8; margin-bottom: 30px;") You are not enrolled in any courses right now.
          a.btn.btn-primary(href="/course") Browse Courses

        .achievements-divider
          .section-title MILESTONES
          h2.section-heading Achievement Gallery

          .achievements-row
            each ach in milestones
              .achievement(class=ach.achieved ? "achieved" : "")
                .ach-icon
                  i(class="fas " + ach.icon)
                  if ach.achieved
                    .ach-badge
                      i.fas.fa-check
                .ach-name= ach.title
            
            a.achievement(href="/certificates", style="text-decoration: none; cursor: pointer;")
              .ach-icon(style="color: var(--text-muted); border-color: rgba(255,255,255,0.05); border-style: dashed; transition: border-color 0.2s, color 0.2s;")
                i.fas.fa-arrow-right
              .ach-name View Gallery

      .sidebar
        .side-card
          h3 Performance Stats
          .stats-grid
            .stat-box
              .label TOTAL XP
              .value= stats.xp
            .stat-box
              .label HOURS LEARNT
              .value.white= stats.hoursLearnt
            .stat-box
              .label SOLVED
              .value.white= stats.solved
            .stat-box
              .label RANK
              .value.white= stats.rank
              if stats.weeklyRank !== 'N/A'
                div(style="font-size: 10px; color: #94a3b8; margin-top: 4px;") Weekly: #{stats.weeklyRank}

        .side-card(style="text-align: center;")
          h3 Weekly Goal
          .goal-circle(style="--pct: " + weeklyGoal.percent + "%;")
            .goal-text
              .pct #{weeklyGoal.percent}%
              .lbl TARGET MET
          p(style="color: #94a3b8; font-size: 13px; margin: 20px 0;")
            | You're only 
            span(style="color: #f2622e; font-weight: 600;") #{weeklyGoal.hoursAway} hours
            |  away from your weekly goal!
          a.continue-btn(style="display: inline-block; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 12px 30px;", href="#") Adjust Goals

        .side-card
          h3 Next Milestones
          each ms in nextMilestones
            .milestone-item
              .ms-icon(style="background: " + ms.color + "20; color: " + ms.color + ";")
                i(class="fas " + ms.icon)
              .ms-details
                h4= ms.title
                p= ms.desc
