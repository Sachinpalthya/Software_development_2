extends layout

block content
  style.
    body {
      background-color: var(--bg-color);
    }
    .gallery-header {
      background: white;
      border-radius: 24px;
      padding: 60px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 40px 0;
      box-shadow: var(--shadow-md);
      position: relative;
      overflow: hidden;
    }
    .gallery-header-content {
      position: relative;
      z-index: 2;
      max-width: 500px;
    }
    .gallery-title {
      font-size: 48px;
      color: var(--text-dark);
      margin: 16px 0 24px;
      line-height: 1.1;
    }
    .gallery-desc {
      font-size: 18px;
      color: var(--text-muted);
      line-height: 1.6;
      margin-bottom: 40px;
    }
    .stats-block {
      display: flex;
      gap: 20px;
    }
    .stat-badge {
      background: var(--gray-100);
      border: 1px solid var(--gray-200);
      padding: 16px 32px;
      border-radius: 16px;
      display: flex;
      flex-direction: column;
    }
    .stat-value {
      font-size: 32px;
      font-weight: 700;
      color: var(--text-dark);
    }
    .stat-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      font-weight: 600;
    }
    .gallery-art {
      width: 400px;
      height: 300px;
      background: url('https://images.unsplash.com/photo-1589330694653-efa64753baaa?auto=format&fit=crop&w=600&q=80') center/cover;
      border-radius: 16px;
      box-shadow: var(--shadow-lg);
      position: relative;
      z-index: 2;
      border: 8px solid white;
    }
    
    .filter-bar {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 40px;
    }
    .filter-search {
      flex: 1;
      position: relative;
    }
    .filter-search input {
      width: 100%;
      padding: 16px 20px 16px 50px;
      border-radius: 12px;
      border: 1px solid var(--gray-200);
      background: white;
      font-size: 16px;
      box-shadow: var(--shadow-sm);
    }
    .filter-search i {
      position: absolute;
      left: 20px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
    }
    .filter-tags {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .filter-tag {
      background: white;
      border: 1px solid var(--gray-200);
      padding: 10px 20px;
      border-radius: 30px;
      font-size: 14px;
      font-weight: 500;
      color: var(--text-dark);
      cursor: pointer;
      transition: all 0.2s;
    }
    .filter-tag:hover, .filter-tag.active {
      background: var(--text-dark);
      color: white;
      border-color: var(--text-dark);
    }

    .cert-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
      margin-bottom: 60px;
    }
    .cert-card {
      background: white;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition: transform 0.2s, box-shadow 0.2s;
      border: 1px solid var(--gray-100);
    }
    .cert-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
    }
    .cert-img {
      height: 200px;
      background-size: cover;
      background-position: center;
      position: relative;
    }
    .cert-tag {
      position: absolute;
      top: 16px;
      right: 16px;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      background: white;
      box-shadow: var(--shadow-sm);
    }
    .cert-body {
      padding: 24px;
    }
    .cert-title {
      font-size: 22px;
      color: var(--text-dark);
      margin-bottom: 12px;
    }
    .cert-desc {
      font-size: 14px;
      color: var(--text-muted);
      margin-bottom: 24px;
      line-height: 1.5;
    }
    .cert-meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 24px;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--gray-100);
    }
    .meta-box {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .meta-lbl {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
    }
    .meta-val {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-dark);
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .cert-actions {
      display: flex;
      gap: 12px;
    }
    .btn-cert {
      flex: 1;
      padding: 10px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      text-align: center;
      transition: all 0.2s;
    }
    .btn-pdf {
      background: var(--gray-100);
      color: var(--text-dark);
    }
    .btn-pdf:hover {
      background: var(--gray-200);
    }
    .btn-linkedin {
      background: #0077b5;
      color: white;
    }
    .btn-linkedin:hover {
      background: #006097;
    }

    .premier-block {
      background: white;
      border: 2px solid rgba(242, 98, 46, 0.2);
      border-radius: 24px;
      padding: 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 80px;
      box-shadow: var(--shadow-md);
      position: relative;
    }
    .premier-block::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 8px;
      background: var(--primary);
      border-radius: 24px 0 0 24px;
    }
    .premier-content {
      max-width: 600px;
    }
    .premier-title {
      font-size: 36px;
      color: var(--text-dark);
      margin: 12px 0 24px;
    }
    .premier-desc {
      font-size: 16px;
      color: var(--text-muted);
      line-height: 1.6;
      margin-bottom: 30px;
    }
    .premier-footer {
      display: flex;
      align-items: center;
      gap: 30px;
    }
    .verified-mark {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .verified-icon {
      width: 40px;
      height: 40px;
      background: var(--gray-100);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-dark);
      font-size: 18px;
    }
    .badge-label {
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--primary);
      font-weight: 700;
      margin-bottom: 8px;
      display: inline-block;
    }

  .container
    .gallery-header
      .gallery-header-content
        span.badge-label MILESTONES REACHED
        h1.gallery-title Your Certificates
        p.gallery-desc Every hour spent mastering a craft is a brick in the foundation of your legacy. Here are the certified proofs of your journey toward skillstreak of S-Five coders.
        .stats-block
          .stat-badge
            span.stat-value #{stats.totalBadges.toString().padStart(2, '0')}
            span.stat-label TOTAL BADGES
          .stat-badge
            span.stat-value(style="color: var(--primary);") #{stats.expertCerts.toString().padStart(2, '0')}
            span.stat-label EXPERT CERTS
      .gallery-art(style="display: flex; align-items: center; justify-content: center; text-align: center; padding: 20px; color: var(--text-dark); background: white;") 
        h2(style="font-size: 28px; line-height: 1.4;")
          span(style="color: var(--primary);") Skill streak lerning palfrom
          br
          | by S-five Coders

    .filter-bar
      .filter-search
        i.fas.fa-search
        input(type="text", placeholder="Search certificates...")
      .filter-tags
        span(style="font-size: 14px; font-weight: 600; margin-right: 8px;") Sort By:
        .filter-tag.active All
        .filter-tag Engineering
        .filter-tag Product
        .filter-tag Design

    .cert-grid
      each cert in certificates
        .cert-card
          .cert-img(style="background-image: url('" + cert.image + "');")
            .cert-tag(style="color: " + cert.tagColor + ";") #{cert.tag}
          .cert-body
            h3.cert-title #{cert.title}
            p.cert-desc #{cert.description}
            .cert-meta
              .meta-box
                span.meta-lbl ISSUE DATE
                span.meta-val #{cert.issueDate}
              .meta-box
                span.meta-lbl AUTHENTICITY ID
                span.meta-val #{cert.authId} 
                  i.fas.fa-check-circle(style="font-size: 12px; color: var(--primary); margin-left: 2px;")
            .cert-actions
              a.btn-cert.btn-pdf(href="#") 
                i.fas.fa-download(style="margin-right: 6px;")
                | PDF
              a.btn-cert.btn-linkedin(href="#")
                i.fab.fa-linkedin(style="margin-right: 6px;")
                | LinkedIn

    h2(style="font-size: 28px; margin-bottom: 24px; color: var(--text-dark);") Premier Accomplishment
    .premier-block
      .premier-content
        span.badge-label CERTIFICATION OF EXCELLENCE
        h2.premier-title #{premier.title}
        p.premier-desc #{premier.credentialText}
        .premier-footer
          .verified-mark
            .verified-icon
              i.fas.fa-shield-alt
            div
              .meta-lbl VERIFIED STATUS
              .meta-val #{premier.verifiedType}
          a.btn.btn-primary(href="#", style="font-size: 14px;") VIEW OFFICIAL VERIFICATION PAGE
      
      div(style="width: 140px; height: 140px; background: white; border: 1px solid var(--gray-200); border-radius: 16px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm); padding: 10px;")
        img(src="https://api.dicebear.com/7.x/identicon/svg?seed=" + premier.title + "&backgroundColor=f7f5f2", style="width: 100%; height: 100%; opacity: 0.5; border-radius: 8px;", alt="QR Seal")
