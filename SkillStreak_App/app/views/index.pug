        .stats(style="display: flex; justify-content: space-between; align-items: center; padding-top: 16px; border-top: 1px solid var(--gray-100);")
          span(style="color: var(--text-muted); font-size: 14px;") Weekly XP Earned
          span(style="font-weight: 700; font-size: 18px;") 13,850

  // Live Event Banner
  section.container(style="margin: 40px auto;")
