        .countdown(style="display: flex; gap: 24px; margin-bottom: 32px;")
          div(style="text-align: center;")
            div(style="font-size: 32px; font-weight: 700;") 02
            div(style="font-size: 10px; color: #9ca3af; text-transform: uppercase; letter-spacing: 1px;") DAYS
          span(style="font-size: 32px; color: #4b5563;") :
          div(style="text-align: center;")
            div(style="font-size: 32px; font-weight: 700;") 14
            div(style="font-size: 10px; color: #9ca3af; text-transform: uppercase; letter-spacing: 1px;") HOURS
          span(style="font-size: 32px; color: #4b5563;") :
          div(style="text-align: center;")
            div(style="font-size: 32px; font-weight: 700;") 35
            div(style="font-size: 10px; color: #9ca3af; text-transform: uppercase; letter-spacing: 1px;") MINS
        a.btn.btn-primary(href="/contest") Competite Now
      .bg-icon(style="position: absolute; right: 80px; top: 50%; transform: translateY(-50%); font-size: 180px; color: rgba(255,255,255,0.05); z-index: 1;") 
        | &lt; / &gt;

  // Popular Learning Paths
  section.container(style="padding: 60px 0;")
    div(style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px;")
      div
        h2(style="font-size: 32px; margin-bottom: 8px;") Popular Learning Paths
        p.text-muted Curated tracks to help you transition to tech.
      div(style="display: flex; gap: 8px;")
        button.btn-outline(style="width: 40px; height: 40px; border-radius: 50%; padding: 0; display: flex; align-items: center; justify-content: center;") &lt;
        button.btn-outline(style="width: 40px; height: 40px; border-radius: 50%; padding: 0; display: flex; align-items: center; justify-content: center;") &gt;
        
    .paths-grid(style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;")
      // Path 1
      .card(style="background: white; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-sm); cursor: pointer; transition: transform 0.2s;")
        .card-img-top(style="hight: 160px; background: #0f766e; color: white; display:flex; align-items:center; justify-content:center; position:relative; padding: 40px;")
          span(style="position:absolute; top:12px; left:12px; background:white; color:#333; font-size:10px; font-weight:bold; padding:4px 8px; border-radius:4px;") Tech
          i.fas.fa-atom(style="font-size: 48px;")
        .card-body(style="padding: 24px;")
          h3(style="font-size: 16px; margin-bottom: 8px; height: 48px;") Mastering React 18 & Advanced Hooks
          .meta(style="font-size: 12px; color: var(--text-muted); display:flex; gap:12px; margin-bottom: 24px;")
            span #[i.far.fa-clock] 12 Hours
            span 15 Lessons
          .card-footer(style="display:flex; justify-content:space-between; align-items:center; border-top: 1px solid var(--gray-100); padding-top: 16px;")
