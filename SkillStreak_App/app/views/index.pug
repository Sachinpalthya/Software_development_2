      .card(style="background: white; border-radius: 16px; padding: 24px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column;")
        .user-header(style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px;")
          .avatar(style="width: 50px; height: 50px; border-radius: 50%; background: #fed7aa; position: relative;")
            .badge(style="position: absolute; bottom: -5px; right: -5px; width: 24px; height: 24px; background: #d97706; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; border: 2px solid white;") 3
          div
            h3(style="font-size: 18px;") pavan palthya
            .streak(style="color: var(--primary); font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 4px;") 
