extends layout

block content
  // Hero Section
  section.hero-section.container(style="display: flex; align-items: center; justify-content: space-between; padding: 60px 0; min-height: 80vh;")
    .hero-content(style="flex: 1; max-width: 600px;")
      span.badge(style="background-color: #ffd8cc; color: var(--primary); padding: 6px 12px; border-radius: 20px; font-weight: 600; font-size: 14px; margin-bottom: 20px; display: inline-block;") ⚡ Level Up Your Career
      h1(style="font-size: 64px; margin-bottom: 24px; color: var(--text-dark);") Let's Master New Skills, #[br] #[span(style="color: var(--primary);") Build Your Streak]
      p(style="font-size: 18px; color: var(--text-muted); margin-bottom: 40px;") Join the most engaging gamified learning platform to level up your career with daily challenges, competitive leaderboards, and a global community of developers.
      div(style="display: flex; gap: 16px;")
        a.btn.btn-primary(href="/register", style="padding: 14px 32px; font-size: 16px;") Get Started Free
        a.btn.btn-outline(href="/course", style="padding: 14px 32px; font-size: 16px;") Browse Courses
      
      div(style="margin-top: 40px; display: flex; align-items: center; gap: 12px; font-size: 14px; color: var(--text-muted);")
        .avatars(style="display: flex;")
          div(style="width:32px; height:32px; border-radius:50%; background:#e2e8f0; border:2px solid white; z-index: 3;")
          div(style="width:32px; height:32px; border-radius:50%; background:#cbd5e1; border:2px solid white; margin-left:-10px; z-index: 2;")
          div(style="width:32px; height:32px; border-radius:50%; background:#94a3b8; border:2px solid white; margin-left:-10px; z-index: 1;")
        span Join us for skill learning 
        
    .hero-image(style="flex: 1; position: relative; text-align: right;")
      img(src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=600&q=80", alt="Coding Environment", style="border-radius: 24px; width: 100%; max-width: 500px; box-shadow: var(--shadow-xl);")
      .floating-card(style="position: absolute; top: -20px; right: 20px; background: white; padding: 12px 20px; border-radius: 12px; display: flex; align-items: center; gap: 12px; box-shadow: var(--shadow-md);")
        i.fas.fa-fire(style="color: var(--primary); font-size: 20px;")
        div
          div(style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase;") Current Streak
          div(style="font-size: 16px; font-weight: 700; color: var(--text-dark);") 14 Days

  // Weekly Hall of Fame
