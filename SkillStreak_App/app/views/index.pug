          span(style="position:absolute; top:12px; left:12px; background:white; color:#333; font-size:10px; font-weight:bold; padding:4px 8px; border-radius:4px;") Data
        .card-body(style="padding: 24px;")
          h3(style="font-size: 16px; margin-bottom: 8px; height: 48px;") Python for Data Analysis Bootcamp
          .meta(style="font-size: 12px; color: var(--text-muted); display:flex; gap:12px; margin-bottom: 24px;")
            span #[i.far.fa-clock] 24 Hours
