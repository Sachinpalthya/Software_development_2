extends layout

block content
  style.
    body {
      background-color: #0b0f19 !important;
      color: #e2e8f0 !important;
    }
    .edit-container {
      max-width: 700px;
      margin: 60px auto;
      background: #151a27;
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 16px;
      padding: 40px;
    }
    .edit-header {
      font-size: 28px;
      color: white;
      margin-bottom: 30px;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .form-group {
      margin-bottom: 24px;
    }
    .form-label {
      display: block;
      color: #94a3b8;
      font-size: 14px;
      margin-bottom: 8px;
      font-weight: 600;
    }
    .form-control, .form-select, .form-textarea {
      width: 100%;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.1);
      color: white;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 15px;
      transition: border-color 0.2s;
    }
    .form-control:focus, .form-select:focus, .form-textarea:focus {
      outline: none;
      border-color: #f2622e;
      background: rgba(255,255,255,0.05);
    }
    option {
      color: black;
    }
    .form-textarea {
      resize: vertical;
      min-height: 100px;
    }
    .photo-upload {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 30px;
    }
    .photo-preview {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      background: #1e293b;
      object-fit: cover;
      border: 2px solid rgba(255,255,255,0.1);
    }
    .upload-btn-wrapper {
      position: relative;
      overflow: hidden;
      display: inline-block;
    }
    .upload-btn {
      background: rgba(242, 98, 46, 0.1);
      color: #f2622e;
      border: 1px solid rgba(242, 98, 46, 0.2);
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .upload-btn:hover {
      background: rgba(242, 98, 46, 0.2);
    }
    .btn-remove {
      background: transparent;
      color: #ef4444;
      border: 1px solid rgba(239, 68, 68, 0.3);
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-remove:hover {
      background: rgba(239, 68, 68, 0.1);
    }
    .upload-btn-wrapper input[type=file] {
      font-size: 100px;
      position: absolute;
      left: 0;
      top: 0;
      opacity: 0;
      cursor: pointer;
    }
    .actions {
      display: flex;
      gap: 16px;
      margin-top: 40px;
    }
    .btn-save {
      background: #f2622e;
      color: white;
      border: none;
      padding: 12px 30px;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-save:hover {
      background: #e05220;
    }
    .btn-cancel {
      background: rgba(255,255,255,0.05);
      color: white;
      text-decoration: none;
      padding: 12px 30px;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      display: flex;
      align-items: center;
      transition: background 0.2s;
    }
    .btn-cancel:hover {
      background: rgba(255,255,255,0.1);
    }

  .container
    .edit-container
      .edit-header 
        i.fas.fa-user-edit
        | Edit Profile
      
      form(action="/profile/edit", method="POST", enctype="multipart/form-data")
        input#removePhotoFlag(type="hidden", name="remove_photo", value="false")
        .photo-upload
          if stats.profilePhoto
            img.photo-preview#previewImage(src=stats.profilePhoto, alt="Profile Photo")
          else
            img.photo-preview#previewImage(src="https://ui-avatars.com/api/?name=" + encodeURIComponent(stats.fullName) + "&background=random&color=fff&size=150", alt="Profile Photo")
          
          .upload-btn-wrapper
            button.upload-btn(type="button") Change Photo
            input#photoInput(type="file", name="profile_photo", accept="image/*")
          
          button.btn-remove#removePhotoBtn(type="button", style="display: " + (stats.profilePhoto ? "inline-block" : "none") + ";") Remove
          
          span#fileName(style="color: #94a3b8; font-size: 13px; margin-left: 10px;") No file chosen

        .form-group
          label.form-label Name
          input.form-control(type="text", name="fullName", value=stats.fullName, required)

        .form-group
          label.form-label Pronouns / Gender
          select.form-select(name="gender")
            option(value="other", selected=(stats.gender !== 'male' && stats.gender !== 'female')) Prefer not to say
            option(value="male", selected=(stats.gender === 'male')) Male
            option(value="female", selected=(stats.gender === 'female')) Female
            

        .form-group
          label.form-label Bio
          textarea.form-textarea(name="bio", placeholder="Tell us a little about yourself...")= stats.bio

        .actions
          button.btn-save(type="submit") Save Changes
          a.btn-cancel(href="/profile") Cancel

  script.
    const photoInput = document.getElementById('photoInput');
    const previewImage = document.getElementById('previewImage');
    const fileName = document.getElementById('fileName');
    const removePhotoBtn = document.getElementById('removePhotoBtn');
    const removePhotoFlag = document.getElementById('removePhotoFlag');
    const defaultAvatarUrl = "https://ui-avatars.com/api/?name=" + encodeURIComponent("!{stats.fullName}") + "&background=random&color=fff&size=150";

    photoInput.addEventListener('change', function() {
      const file = this.files[0];
      if (file) {
        fileName.textContent = file.name;
        removePhotoFlag.value = "false";
        removePhotoBtn.style.display = "inline-block";
        const reader = new FileReader();
        reader.onload = function(e) {
          previewImage.src = e.target.result;
        }
        reader.readAsDataURL(file);
      } else {
        fileName.textContent = "No file chosen";
      }
    });

    if (removePhotoBtn) {
      removePhotoBtn.addEventListener('click', function() {
        photoInput.value = "";
        fileName.textContent = "No file chosen";
        removePhotoFlag.value = "true";
        previewImage.src = defaultAvatarUrl;
        this.style.display = "none";
      });
    }
